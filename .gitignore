# =========================
# PYTHON
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# ENV / IDE
# =========================
.env
.venv/
venv/
env/
.idea/
.vscode/

# =========================
# OS FILES
# =========================
.DS_Store
Thumbs.db

# =========================
# DATA (IGNORE HEAVY FILES ONLY)
# =========================
data/
analysis/

# Ignore CSV only inside data folders
data/**/*.csv
analysis/**/*.csv

# Ignore Excel inside data folders
data/**/*.xlsx
analysis/**/*.xlsx

# =========================
# KEEP IMPORTANT CONFIG
# =========================
!config/*.csv

# =========================
# LOGS / OUTPUTS
# =========================
logs/
*.log
*.out
*.tmp

# =========================
# BACKUPS
# =========================
*.bak
*.old
# =====================
